generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  phone     String
  password  String

  role      UserRole @default(CUSTOMER)

  createdAt DateTime @default(now())

  orders    Order[]  
  activityLogs ActivityLog[]
}

enum PaymentStatus {
  pending
  paid
  failed
}

model Order {
  id                  String   @id @default(uuid())
  userId              String
  vehicle             String

  pickup_address      String
  destination_address String

  distance            Float
  duration            Float
  price               Int

  payment_status      PaymentStatus   @default(pending)
  payment_method      String?
  payment_type        String?
  transaction_id      String?
  snap_token          String?

   fraud_status        String?

  order_status        String   @default("menunggu")

  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // Contoh: "LOGIN", "LOGOUT", "DELETE_USER", "UPDATE_ORDER"
  details   String?  // Info tambahan (misal: "Menghapus user ID: xxx")
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}